<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog
        title="{/confirmTitle}"
        type="Message"
        state="{/confirmState}">
        <content>
            <Text text="{/confirmMessage}" class="sapUiSmallMargin"/>
        </content>
        <beginButton>
            <Button
                text="{/confirmButtonText}"
                type="{/confirmButtonType}"
                press="onConfirmAction"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press="onCancelConfirm"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
