<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Popover
        title="Notifications"
        placement="Bottom"
        contentWidth="400px"
        contentHeight="500px">
        <content>
            <List
                items="{/notifications}"
                noDataText="No notifications">
                <FeedListItem
                    sender="{sender}"
                    text="{message}"
                    timestamp="{timestamp}"
                    icon="{icon}"
                    iconActive="false"/>
            </List>
        </content>
        <footer>
            <Toolbar>
                <Button text="Clear All" press="onClearNotifications"/>
                <ToolbarSpacer/>
                <Button text="Close" press="onCloseNotifications"/>
            </Toolbar>
        </footer>
    </Popover>
</core:FragmentDefinition>
